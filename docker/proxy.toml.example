# Example config for running inside the container (paths are container-local).
# Copy to proxy.toml and adjust routes/upstreams.

[server]
listen = "0.0.0.0:8443"
cert = "/etc/qrux/certs/cert.pem"
key = "/etc/qrux/certs/key.pem"
metrics_listen = "0.0.0.0:9090"
https_listen = "0.0.0.0:8444"

# Optional — see docs (Production / Configuration)
# [server.limits]
# upstream_connect_timeout_secs = 10
# upstream_request_timeout_secs = 120

[[routes]]
match = "*"
upstream = "example.com:80"
